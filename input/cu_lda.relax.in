&CONTROL
  calculation = 'relax',
  prefix = 'cu_lda',
  outdir = './work',
  pseudo_dir = './pseudo',
  tprnfor = .true.,
  tstress = .true.,
  etot_conv_thr = 1.0d-5,
  forc_conv_thr = 1.0d-4
/

&SYSTEM
  ibrav = 0,
  nat = 2,
  ntyp = 1,
  ecutwfc = 60,
  ecutrho = 480,
  occupations = 'smearing',
  smearing = 'mp',
  degauss = 0.02
/

&ELECTRONS
  conv_thr = 1.0d-8,
  mixing_beta = 0.3
/

&IONS
  ion_dynamics = 'bfgs'
/

ATOMIC_SPECIES
  Cu  63.546  Cu.pbe-spn-kjpaw_psl.1.0.0.UPF


CELL_PARAMETERS angstrom
  3.44  0.00  0.00
  0.00  3.44  0.00
  0.00  0.00  3.44

ATOMIC_POSITIONS crystal
  Cu  0.0  0.0  0.0
  Cu  0.5  0.5  0.5

K_POINTS automatic
  4 4 4  1 1 1
